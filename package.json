{
  "name": "@misterpea/schwab-node",
  "version": "0.2.0",
  "license": "MIT",
  "author": "Perry Angelora <perry.angelora@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/MisterPea/schwab-node"
  },
  "description": "A Node.js wrapper for Schwab's Market Data API — get quotes, option chains, price history, and more with minimal setup",
  "keywords": [
    "schwab",
    "schwab-api",
    "charles-schwab",
    "trading-api",
    "brokerage-api",
    "finance-api",
    "oauth2",
    "authentication",
    "nodejs",
    "typescript"
  ],
  "engines": {
    "node": ">=20.6.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "schwab-node-certs": "./dist/scripts/setup-certs.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./types_internal": {
      "types": "./dist/types_internal.d.ts",
      "import": "./dist/types_internal.js"
    },
    "./helpers": {
      "types": "./dist/helpers.d.ts",
      "import": "./dist/helpers.js"
    },
    "./oauth/schwabAuth": {
      "types": "./dist/oauth/schwabAuth.d.ts",
      "import": "./dist/oauth/schwabAuth.js"
    },
    "./oauth/defaultAuth": {
      "types": "./dist/oauth/defaultAuth.d.ts",
      "import": "./dist/oauth/defaultAuth.js"
    },
    "./oauth/tokenStore": {
      "types": "./dist/oauth/tokenStore.d.ts",
      "import": "./dist/oauth/tokenStore.js"
    },
    "./oauth/server": {
      "types": "./dist/oauth/server.d.ts",
      "import": "./dist/oauth/server.js"
    },
    "./scripts/request": {
      "types": "./dist/scripts/request.d.ts",
      "import": "./dist/scripts/request.js"
    },
    "./scripts/setup-certs": {
      "types": "./dist/scripts/setup-certs.d.ts",
      "import": "./dist/scripts/setup-certs.js"
    },
    "./account": {
      "types": "./dist/account/index.d.ts",
      "import": "./dist/account/index.js"
    },
    "./account/account-numbers": {
      "types": "./dist/account/account-numbers/index.d.ts",
      "import": "./dist/account/account-numbers/index.js"
    },
    "./account/accounts": {
      "types": "./dist/account/accounts/index.d.ts",
      "import": "./dist/account/accounts/index.js"
    },
    "./account/user-preference": {
      "types": "./dist/account/user-preference/index.d.ts",
      "import": "./dist/account/user-preference/index.js"
    },
    "./market-data": {
      "types": "./dist/market-data/index.d.ts",
      "import": "./dist/market-data/index.js"
    },
    "./market-data/get-market-hours": {
      "types": "./dist/market-data/get-market-hours/index.d.ts",
      "import": "./dist/market-data/get-market-hours/index.js"
    },
    "./market-data/get-movers": {
      "types": "./dist/market-data/get-movers/index.d.ts",
      "import": "./dist/market-data/get-movers/index.js"
    },
    "./market-data/get-quote": {
      "types": "./dist/market-data/get-quote/index.d.ts",
      "import": "./dist/market-data/get-quote/index.js"
    },
    "./market-data/price-history": {
      "types": "./dist/market-data/price-history/index.d.ts",
      "import": "./dist/market-data/price-history/index.js"
    },
    "./derivatives": {
      "types": "./dist/derivatives/index.d.ts",
      "import": "./dist/derivatives/index.js"
    },
    "./derivatives/get-option-chain": {
      "types": "./dist/derivatives/get-option-chain/index.d.ts",
      "import": "./dist/derivatives/get-option-chain/index.js"
    },
    "./derivatives/get-option-expirations": {
      "types": "./dist/derivatives/get-option-expirations/index.d.ts",
      "import": "./dist/derivatives/get-option-expirations/index.js"
    },
    "./derivatives/get-atm-option-data": {
      "types": "./dist/derivatives/get-atm-option-data/index.d.ts",
      "import": "./dist/derivatives/get-atm-option-data/index.js"
    },
    "./derivatives/greek-filter": {
      "types": "./dist/derivatives/greek-filter/index.d.ts",
      "import": "./dist/derivatives/greek-filter/index.js"
    },
    "./derivatives/schema": {
      "types": "./dist/derivatives/schema.d.ts",
      "import": "./dist/derivatives/schema.js"
    },
    "./marketData/quotes": {
      "types": "./dist/marketData/quotes.d.ts",
      "import": "./dist/marketData/quotes.js"
    },
    "./marketData/derivatives": {
      "types": "./dist/marketData/derivatives.d.ts",
      "import": "./dist/marketData/derivatives.js"
    },
    "./marketData/highLevelData": {
      "types": "./dist/marketData/highLevelData.d.ts",
      "import": "./dist/marketData/highLevelData.js"
    },
    "./marketData/request": {
      "types": "./dist/marketData/request.d.ts",
      "import": "./dist/marketData/request.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "tsx watch src/index.ts",
    "test": "vitest run --exclude \"test/**/*.live.test.ts\"",
    "test:contract": "vitest run -c vitest.contract.config.ts",
    "test:live:smoke": "vitest run -c vitest.live-smoke.config.ts",
    "prepack": "npm run build",
    "certs:install": "node --import tsx src/scripts/setup-certs.ts",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format --check .",
    "coverage": "vitest run --coverage",
    "build": "tsc"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.0",
    "@vitest/coverage-v8": "^4.0.15",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "@biomejs/biome": "^2.4.4",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  }
}
